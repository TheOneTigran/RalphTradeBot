# Bybit API Keys (можно оставить пустыми для публичного доступа к рыночным данным)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# OpenRouter (https://openrouter.ai) — используется как LLM-провайдер
# Ключ берётся с https://openrouter.ai/keys (бесплатная регистрация)
OPENAI_API_KEY=sk-or-v1-...
OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Бесплатные модели OpenRouter (limit: бесплатный тариф, нет гарантии JSON mode)
OPENAI_MODEL=stepfun/step-3.5-flash:free
# Другие бесплатные варианты:
# OPENAI_MODEL=google/gemini-2.0-flash-exp:free
# OPENAI_MODEL=deepseek/deepseek-r1:free
# OPENAI_MODEL=meta-llama/llama-4-maverick:free

# Настройки анализа
# Список монет для анализа, через запятую
SYMBOLS=BTCUSDT,ETHUSDT

# Таймфреймы для анализа (от старшего к младшему, через запятую)
TIMEFRAMES=1w,1d,4h,1h,15m,5m

# Порог аномального объема (кратно SMA)
VOLUME_ANOMALY_MULTIPLIER=2.5
VOLUME_ANOMALY_PERIOD=20

# Количество свечей для выкачки на каждый ТФ
CANDLE_LIMIT=500
